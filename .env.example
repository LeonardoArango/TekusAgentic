# Copiar a .env y completar con valores reales. Nunca commitear .env.
# En prod, estas variables se gestionan vía Doppler o SOPS, no como .env plano.

# --- WhatsApp Cloud API (Meta) ---
META_WA_TOKEN=
META_WA_PHONE_NUMBER_ID=
META_WA_BUSINESS_ACCOUNT_ID=
META_WA_VERIFY_TOKEN=
META_WA_APP_SECRET=

# --- Odoo (CRM + Helpdesk, vía OdooRPC) ---
ODOO_URL=
ODOO_DB=
ODOO_USERNAME=
ODOO_PASSWORD=
# Crear tickets reales en Odoo al escalar. Apagado por defecto; encender solo
# apuntando a una instancia de PRUEBAS (nunca producción sin confirmar).
ODOO_TICKET_WRITE_ENABLED=
# Instancia de PRUEBAS a la que se escriben los tickets (separada de la
# principal de lectura). ODOO_API_KEY_TEST puede ser una API Key de Odoo.
ODOO_URL_TEST=
ODOO_DB_TEST=
ODOO_USERNAME_TEST=
ODOO_API_KEY_TEST=

# --- Confluence (vía atlassian-python-api) ---
CONFLUENCE_URL=
CONFLUENCE_USERNAME=
CONFLUENCE_API_TOKEN=

# --- SSO Microsoft 365 / Entra ID (MSAL) ---
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# --- LLM (Anthropic Claude) — cerebro del Agente de Soporte/Router ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-5

# --- LLM (OpenAI) — solo para el endpoint de preguntas al RAG de la plataforma web ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- RAG: embeddings y reranker autohospedados (ver docs/investigacion-arquitectura.md sección 4) ---
EMBEDDINGS_SERVICE_URL=
RERANKER_SERVICE_URL=

# --- Postgres + pgvector ---
POSTGRES_USER=tekus
POSTGRES_PASSWORD=tekus
POSTGRES_DB=tekus_agente
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://tekus:tekus@localhost:5432/tekus_agente  # pragma: allowlist secret

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# --- Puertos locales de desarrollo ---
BACKEND_PORT=8000
FRONTEND_PORT=4200

# --- CORS: origen del frontend que puede llamar al backend ---
FRONTEND_ORIGIN=http://localhost:4200
