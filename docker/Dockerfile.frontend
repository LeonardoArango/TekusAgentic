FROM node:22-slim AS build

WORKDIR /app
COPY frontend/package*.json ./
RUN npm ci
COPY frontend/ ./
# docker-compose es para desarrollo local: usar la configuración "development"
# (environment.development.ts) en vez de "production" (environment.ts, vacío
# hasta que exista despliegue real).
RUN npx ng build --configuration=development

FROM node:22-slim

WORKDIR /app
COPY --from=build /app/dist ./dist
RUN npm install -g http-server

CMD ["http-server", "dist/frontend/browser", "-p", "4200"]
